# Gemini API keys — get free keys at https://aistudio.google.com/apikey
# Use comma-separated keys for round-robin rotation (avoids rate limits)
GEMINI_API_KEYS=key1,key2,key3

# Or a single key:
# GEMINI_API_KEY=your_single_key

# Optional: override the default model
# GEMINI_MODEL=gemini-2.5-flash
